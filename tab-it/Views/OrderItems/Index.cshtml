@model IReadOnlyList<OrderItem>

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li aria-current="page">Order Items</li></ol></nav>
}

<section class="app-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <h1 class="m-0">Order Items</h1>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <input type="search"
                   class="form-control js-live-search"
                   placeholder="Search order items"
                   data-search-url="@Url.Action("Search")"
                   data-target="#order-items-table-body" />
            <a asp-action="Create" class="btn btn-primary ajax-modal-link" data-title="Order Items">Add New</a>
        </div>
    </div>
    <table class="table app-table">
        <thead><tr><th>Id</th><th>Order Id</th><th>Product Id</th><th>Qty</th><th></th></tr></thead>
        <tbody id="order-items-table-body">
            @await Html.PartialAsync("_Rows", Model)
        </tbody>
    </table>
</section>
