@model tab_it.Models.Domain.Order

<h1>Create Order</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="OrderNumber" class="control-label"></label>
                <input asp-for="OrderNumber" class="form-control" />
                <span asp-validation-for="OrderNumber" class="text-danger"></span>
            </div>

            @await Html.PartialAsync("_DateTimePicker", Model.OrderedAt, new ViewDataDictionary(ViewData) { { "Field", "OrderedAt" } })

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<OrderStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Subtotal" class="control-label"></label>
                <input asp-for="Subtotal" asp-format="{0:0.00}" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Subtotal" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="DiscountPercent" class="control-label"></label>
                <input asp-for="DiscountPercent" asp-format="{0:0.00}" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="DiscountPercent" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Total" class="control-label"></label>
                <input asp-for="Total" asp-format="{0:0.00}" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>

            @await Html.PartialAsync("_CustomerTabAutocomplete", Model)
            
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}