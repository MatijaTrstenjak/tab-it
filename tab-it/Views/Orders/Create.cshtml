@model tab_it.Models.Domain.Order

<h1>Create Order</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="OrderNumber" class="control-label"></label>
                <input asp-for="OrderNumber" class="form-control" />
                <span asp-validation-for="OrderNumber" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Subtotal" class="control-label"></label>
                <input asp-for="Subtotal" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Subtotal" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="DiscountPercent" class="control-label"></label>
                <input asp-for="DiscountPercent" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="DiscountPercent" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Total" class="control-label"></label>
                <input asp-for="Total" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerTabId" class="control-label">Tab ID</label>
                <input asp-for="CustomerTabId" type="number" class="form-control" />
                <span asp-validation-for="CustomerTabId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}