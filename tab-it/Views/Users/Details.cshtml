@model tab_it.Models.ViewModels.IdentityUserListItemViewModel

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li><a asp-action="Index">Users</a></li><li aria-current="page">Details</li></ol></nav>
}

<section class="app-panel">
    <h1>User Details</h1>
    <dl class="row">
        <dt class="col-sm-3">Id</dt><dd class="col-sm-9">@Model.Id</dd>
        <dt class="col-sm-3">Username</dt><dd class="col-sm-9">@Model.UserName</dd>
        <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Email confirmed</dt><dd class="col-sm-9">@Model.EmailConfirmed</dd>
        <dt class="col-sm-3">Roles</dt><dd class="col-sm-9">@(Model.Roles.Count == 0 ? "No roles" : string.Join(", ", Model.Roles))</dd>
        <dt class="col-sm-3">OIB</dt><dd class="col-sm-9">@Model.OIB</dd>
        <dt class="col-sm-3">JMBG</dt><dd class="col-sm-9">@Model.JMBG</dd>
    </dl>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
</section>
