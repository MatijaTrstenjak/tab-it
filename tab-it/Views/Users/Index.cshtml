@model IReadOnlyList<tab_it.Models.ViewModels.IdentityUserListItemViewModel>

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li aria-current="page">Users</li></ol></nav>
}

<section class="app-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <h1 class="m-0">Users</h1>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <input type="search"
                   class="form-control js-live-search"
                   placeholder="Search users"
                   data-search-url="@Url.Action("Search")"
                   data-target="#users-table-body" />
            <a asp-action="Create" class="btn btn-primary">Add New</a>
        </div>
    </div>
    <table class="table app-table">
        <thead><tr><th>Email</th><th>Username</th><th>Roles</th><th>OIB</th><th>JMBG</th><th></th></tr></thead>
        <tbody id="users-table-body">
            @await Html.PartialAsync("_Rows", Model)
        </tbody>
    </table>
</section>
