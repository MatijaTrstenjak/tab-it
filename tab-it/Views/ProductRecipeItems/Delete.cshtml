@model ProductRecipeItem

<section class="app-panel">
    <h1>Delete Recipe Item</h1>
    <p class="app-panel-lead">Remove this inventory item from the recipe.</p>
    <dl class="row">
        <dt class="col-sm-4">Menu item</dt>
        <dd class="col-sm-8">@(Model.Product?.Name ?? $"Product {Model.ProductId}")</dd>
        <dt class="col-sm-4">Inventory item</dt>
        <dd class="col-sm-8">@(Model.InventoryItem?.Name ?? $"Inventory {Model.InventoryItemId}")</dd>
        <dt class="col-sm-4">Required</dt>
        <dd class="col-sm-8">@Model.QuantityRequired.ToString("0.###") @(Model.InventoryItem?.Unit.ToString() ?? string.Empty)</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
    </form>
</section>
