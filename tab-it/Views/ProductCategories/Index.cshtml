@model IReadOnlyList<ProductCategory>

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li aria-current="page">Product Categories</li></ol></nav>
}

<section class="app-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <h1 class="m-0">Product Categories</h1>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <input type="search"
                   class="form-control js-live-search"
                   placeholder="Search categories"
                   data-search-url="@Url.Action("Search")"
                   data-target="#categories-table-body" />
            <a asp-action="Create" class="btn btn-primary ajax-modal-link" data-title="Product Categories">Add New</a>
        </div>
    </div>
    <table class="table app-table">
        <thead><tr><th>Id</th><th>Name</th><th>Description</th><th></th></tr></thead>
        <tbody id="categories-table-body">
            @await Html.PartialAsync("_Rows", Model)
        </tbody>
    </table>
</section>
