@model ProductCategory

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li><a asp-action="Index">Product Categories</a></li><li aria-current="page">Details</li></ol></nav>
}

<section class="app-panel">
    <h1>Category Details</h1>
    <dl class="row">
        <dt class="col-sm-3">Id</dt><dd class="col-sm-9">@Model.Id</dd>
        <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
        <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
    </dl>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
</section>
