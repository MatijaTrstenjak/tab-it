@model tab_it.Models.Domain.CustomerTab

<h1>Delete Customer Tab</h1>

<hr />
<h5>Are you sure you want to delete this tab?</h5>

<dl class="row">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.TabCode</dd>
    <dt class="col-sm-3">Table</dt>
    <dd class="col-sm-9">@Model.TableNumber</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
