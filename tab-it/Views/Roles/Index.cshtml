@model IReadOnlyList<Role>

@section Breadcrumbs {
    <nav aria-label="breadcrumb" class="app-breadcrumbs"><ol><li><a asp-controller="Home" asp-action="Dashboard">Home</a></li><li aria-current="page">Roles</li></ol></nav>
}

<section class="app-panel">
    <h1>Roles</h1>
    <table class="table app-table">
        <thead><tr><th>Id</th><th>Name</th><th>Description</th><th></th></tr></thead>
        <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.Id</td><td>@role.Name</td><td>@role.Description</td>
                <td><a asp-action="Details" asp-route-id="@role.Id">Details</a></td>
            </tr>
        }
        </tbody>
    </table>
</section>
