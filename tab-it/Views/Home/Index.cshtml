@{
    ViewData["Title"] = "Home Page";
    ViewData["HideShell"] = true;
    ViewData["BodyClass"] = "coffee-landing-page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
}

<section class="ij-landing">
    <div class="ij-window">
        <div class="ij-window-bar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
            <span class="ij-window-title">tab-it | Coffee Shop Operations Hub</span>
        </div>

        <div class="ij-content">
            <div class="ij-brand">
                <img src="~/images/tab-it.svg" alt="tab-it logo" class="ij-logo" />
                <div>
                    <h1>tab-it</h1>
                    <p>One dashboard for inventory, POS, staff shifts, and daily sales.</p>
                </div>
            </div>

            <div class="ij-actions" aria-label="Primary actions">
                <a class="ij-btn ij-btn-primary" asp-controller="Home" asp-action="Privacy">Start Shift</a>
                <a class="ij-btn ij-btn-secondary" asp-controller="Home" asp-action="Privacy">Check Inventory</a>
            </div>

            <div class="ij-panels">
                <article class="ij-panel">
                    <h2>Inventory</h2>
                    <p>Track beans, milk, syrups, cups, and reorder thresholds in real time.</p>
                </article>
                <article class="ij-panel">
                    <h2>POS</h2>
                    <p>Handle dine-in and takeaway orders fast with clear ticket flow.</p>
                </article>
                <article class="ij-panel">
                    <h2>Reports</h2>
                    <p>Review top products, peak hours, and shift revenue at a glance.</p>
                </article>
            </div>
        </div>
    </div>
</section>
