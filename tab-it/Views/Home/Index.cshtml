@{
    ViewData["Title"] = "Home Page";
    ViewData["HideShell"] = true;
    ViewData["BodyClass"] = "coffee-landing-page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
}

<section class="ux-landing">
    <main class="ux-hero" role="main">
        <div class="ux-hero-content">
            <p class="ux-kicker">tab-it | Store Operations</p>
            <h1>Run every shift with calm clarity.</h1>
            <p class="ux-lead">tab-it brings inventory, POS, team status, and sales performance into one responsive workspace for fast daily decisions.</p>

            <div class="ux-actions" aria-label="Primary actions">
                <a class="ux-btn ux-btn-primary" asp-controller="Home" asp-action="Dashboard">Open Dashboard</a>
                <a class="ux-btn ux-btn-secondary" asp-controller="Home" asp-action="POS" style="margin-left: 1rem; background-color: #E88B00; color: #fff; border: 2px solid #000; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 999px; font-weight: bold; box-shadow: 4px 4px 0px rgba(0,0,0,1); transition: transform 0.1s ease, box-shadow 0.1s ease;">Launch POS</a>
            </div>
        </div>
        
        <div class="ux-hero-image">
            <img src="~/images/landing-coffee.jpg" alt="Rich espresso and fresh coffee beans on a wooden table" />
        </div>
    </main>
</section>
