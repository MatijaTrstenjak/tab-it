@{
    ViewData["Title"] = "POS Terminal";
    ViewData["HideShell"] = true;
    Layout = "_Layout";
}
@using tab_it.Models.Domain
@using System.Text.Json

<style>
    :root {
        --pos-bg: #F9F6F0; /* warm beige */
        --pos-card: #FFFFFF;
        --pos-border: #000000;
        --pos-accent: #E88B00; /* warm orange */
        --pos-text: #1C1C1C;
        --pos-radius: 12px;
        --pos-pill: 9999px;
    }

    body.pos-mode {
        background-color: var(--pos-bg);
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--pos-text);
        overflow: hidden; /* Prevent body scrolling if possible */
    }

    .pos-container {
        display: grid;
        grid-template-columns: 200px 1fr 300px;
        height: 100vh;
        width: 100%;
        gap: 1rem;
        padding: 1rem;
        box-sizing: border-box;
        background-color: var(--pos-bg);
    }

    /* Common Card Styles */
    .pos-panel {
        background: var(--pos-card);
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        padding: 1rem;
        box-shadow: 4px 4px 0px rgba(0,0,0,1); /* Neo-brutalist touch */
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-sizing: border-box;
    }
    
    .pos-panel-title {
        font-weight: 700;
        font-size: 1.25rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--pos-border);
    }

    /* Left: Categories */
    .pos-categories {
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .category-btn {
        background: var(--pos-bg);
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 0.75rem 1rem;
        font-weight: bold;
        cursor: pointer;
        text-align: left;
        transition: all 0.2s ease;
    }
    .category-btn:hover {
        background: var(--pos-accent);
        color: #fff;
    }
    .category-btn.active {
        background: var(--pos-accent);
        color: #fff;
        box-shadow: 2px 2px 0px rgba(0,0,0,1);
    }

    /* Middle: Products */
    .pos-products {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 1rem;
        overflow-y: auto;
        align-content: start;
        padding-bottom: 1rem;
    }

    .product-card {
        background: var(--pos-card);
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        padding: 1rem;
        text-align: center;
        cursor: pointer;
        transition: transform 0.1s ease, box-shadow 0.1s;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 120px;
        user-select: none;
    }
    .product-card:hover {
        transform: translateY(-2px);
        box-shadow: 4px 4px 0px rgba(0,0,0,1);
    }
    .product-card:active {
        transform: translateY(2px);
        box-shadow: 0px 0px 0px rgba(0,0,0,1);
    }
    .product-name {
        font-weight: 600;
        font-size: 1.1rem;
    }
    .product-price {
        font-weight: 800;
        color: var(--pos-accent);
        margin-top: 0.75rem;
        font-size: 1.1rem;
    }

    /* Right: Receipt */
    .pos-receipt {
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .receipt-items {
        flex: 1;
        overflow-y: auto;
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        padding: 0.5rem;
        background: var(--pos-bg);
        margin-bottom: 1rem;
    }
    .receipt-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0.5rem;
        border-bottom: 1px dashed var(--pos-border);
    }
    .receipt-item:last-child {
        border-bottom: none;
    }
    .item-qty {
        font-weight: bold;
        margin-right: 0.5rem;
        background: var(--pos-border);
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.9em;
    }
    .item-name {
        flex: 1;
        font-weight: 600;
    }
    .item-total {
        font-weight: bold;
        margin-left: 0.5rem;
    }

    .receipt-total {
        font-size: 1.5rem;
        font-weight: 800;
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-top: 1rem;
        border-top: 2px solid var(--pos-border);
    }

    .btn-checkout {
        background: var(--pos-accent);
        color: #fff;
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 1.25rem;
        font-weight: 900;
        font-size: 1.25rem;
        cursor: pointer;
        text-transform: uppercase;
        box-shadow: 4px 4px 0px rgba(0,0,0,1);
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        margin-top: auto;
    }
    .btn-checkout:active {
        transform: translateY(4px);
        box-shadow: 0px 0px 0px rgba(0,0,0,1);
    }
    .btn-checkout:hover {
        filter: brightness(1.05);
    }

    /* Header Nav in POS */
    .pos-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--pos-border);
    }
    .pos-nav-logo {
        font-weight: 900;
        font-size: 1.25rem;
        color: var(--pos-text);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .pos-nav-exit {
        font-weight: bold;
        color: var(--pos-text);
        text-decoration: none;
        border: 2px solid var(--pos-border);
        padding: 0.25rem 0.75rem;
        border-radius: var(--pos-pill);
        transition: background 0.2s;
        font-size: 0.9rem;
    }
    .pos-nav-exit:hover {
        background: #f0f0f0;
    }

    .pos-tab-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .pos-tab-current {
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .pos-tab-btn {
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 0.4rem 0.85rem;
        font-weight: 800;
        background: var(--pos-bg);
        cursor: pointer;
    }

    .pos-tab-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 20;
    }

    .pos-tab-overlay.active {
        display: flex;
    }

    .pos-tab-panel {
        width: min(560px, 90vw);
        background: var(--pos-card);
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        box-shadow: 8px 8px 0px rgba(0,0,0,1);
        padding: 1rem;
        box-sizing: border-box;
    }

    .pos-tab-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--pos-border);
    }

    .pos-tab-panel-title {
        font-size: 1.25rem;
        font-weight: 900;
    }

    .pos-tab-panel-close {
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 0.25rem 0.75rem;
        font-weight: 800;
        background: var(--pos-bg);
        cursor: pointer;
    }

    .pos-open-tabs {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .pos-tab-entry {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: space-between;
    }

    .pos-tab-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pos-open-tab-btn {
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 0.4rem 0.75rem;
        font-weight: 700;
        background: var(--pos-bg);
        cursor: pointer;
    }

    .pos-open-tab-btn.active {
        background: var(--pos-accent);
        color: #fff;
        box-shadow: 2px 2px 0px rgba(0,0,0,1);
    }

    .pos-tab-status {
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        padding: 0.35rem 0.6rem;
        font-weight: 700;
        background: #fff;
        min-width: 140px;
        box-sizing: border-box;
    }

    .pos-new-tab {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .pos-new-tab input {
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-radius);
        padding: 0.5rem 0.6rem;
        font-weight: 600;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

    .pos-new-tab button {
        grid-column: span 2;
        border: 2px solid var(--pos-border);
        border-radius: var(--pos-pill);
        padding: 0.6rem 1rem;
        font-weight: 900;
        background: var(--pos-accent);
        color: #fff;
        cursor: pointer;
        width: 100%;
        box-sizing: border-box;
    }
</style>

<div class="pos-container">
    <!-- Categories -->
    <div class="pos-panel">
        <div class="pos-nav">
            <a href="/" class="pos-nav-logo">
                <img src="~/images/tab-it.svg" width="20" height="20" alt="" />
                <span>tab_it</span>
            </a>
            <a href="/" class="pos-nav-exit">Exit</a>
        </div>
        <h2 class="pos-panel-title">Categories</h2>
        <div class="pos-categories" id="categoryList">
            <!-- Populated by JS -->
        </div>
    </div>

    <!-- Products -->
    <div class="pos-panel">
        <h2 class="pos-panel-title" id="currentCategoryTitle">All Items</h2>
        <div class="pos-products" id="productList">
            <!-- Populated by JS -->
        </div>
    </div>

    <!-- Receipt -->
    <div class="pos-panel pos-receipt">
        <div class="pos-tab-row">
            <h2 class="pos-panel-title" style="margin-bottom: 0;">Current Order</h2>
            <button class="pos-tab-btn" type="button" onclick="openTabPanel()">Tabs</button>
        </div>
        <div class="pos-tab-current" id="currentTabLabel">No tab selected</div>
        @Html.AntiForgeryToken()
        <div class="receipt-items" id="receiptList">
            <!-- Populated by JS -->
        </div>
        
        <div class="receipt-total">
            <span>Total</span>
            <span id="receiptTotal">$0.00</span>
        </div>

        <button class="btn-checkout" onclick="checkout()">Pay / Charge</button>
    </div>
</div>

<div class="pos-tab-overlay" id="tabOverlay">
    <div class="pos-tab-panel">
        <div class="pos-tab-panel-header">
            <div class="pos-tab-panel-title">Manage Tabs</div>
            <button class="pos-tab-panel-close" type="button" onclick="closeTabPanel()">Close</button>
        </div>
        <div class="pos-open-tabs" id="openTabsList"></div>
        <div class="pos-new-tab">
            <input id="newTabTable" type="number" min="1" placeholder="Table #" />
            <input id="newTabNotes" type="text" maxlength="500" placeholder="Notes (optional)" />
            <button type="button" onclick="createTab()">Open New Tab</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.body.classList.add('pos-mode');

        // Data from Repositories
        const categories = @Html.Raw(JsonSerializer.Serialize(ViewData["Categories"] ?? new List<ProductCategory>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase, ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles }));
        const products = @Html.Raw(JsonSerializer.Serialize(ViewData["Products"] ?? new List<Product>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase, ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles }));
        const tabs = @Html.Raw(JsonSerializer.Serialize(ViewData["Tabs"] ?? new List<CustomerTab>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase, ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles }));

        let currentCategoryId = null;
        let order = [];
        let currentTabId = null;

        function renderTabs() {
            const openTabsList = document.getElementById('openTabsList');
            openTabsList.innerHTML = '';

            const openTabs = tabs.filter(t => t.status !== 2);
            openTabs.forEach(t => {
                const entry = document.createElement('div');
                entry.className = 'pos-tab-entry';

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'pos-open-tab-btn' + (currentTabId === t.id ? ' active' : '');
                btn.textContent = `Table ${t.tableNumber}`;
                btn.onclick = () => {
                    currentTabId = t.id;
                    renderTabs();
                    renderCurrentTab();
                    closeTabPanel();
                };

                const actions = document.createElement('div');
                actions.className = 'pos-tab-actions';

                const statusSelect = document.createElement('select');
                statusSelect.className = 'pos-tab-status';
                statusSelect.innerHTML = `
                    <option value="1">Open</option>
                    <option value="2">Closed</option>
                    <option value="3">Cancelled</option>
                `;
                statusSelect.value = String(t.status);
                statusSelect.onchange = () => updateTabStatus(t.id, parseInt(statusSelect.value, 10));

                actions.appendChild(statusSelect);
                entry.appendChild(btn);
                entry.appendChild(actions);
                openTabsList.appendChild(entry);
            });
        }

        function renderCurrentTab() {
            const label = document.getElementById('currentTabLabel');
            const tab = tabs.find(t => t.id === currentTabId);
            label.textContent = tab
                ? `${tab.tabCode} (Table ${tab.tableNumber})`
                : 'No tab selected';
        }

        function openTabPanel() {
            document.getElementById('tabOverlay').classList.add('active');
            renderTabs();
        }

        function closeTabPanel() {
            document.getElementById('tabOverlay').classList.remove('active');
        }

        function createTab() {
            const tableInput = document.getElementById('newTabTable');
            const notesInput = document.getElementById('newTabNotes');
            const tableNumber = parseInt(tableInput.value, 10);
            if (!tableNumber) {
                alert('Enter a table number.');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const payload = {
                tableNumber,
                notes: notesInput.value
            };

            fetch('@Url.Action("CreateTab", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Create tab failed.');
                    }
                    return response.json();
                })
                .then(data => {
                    tabs.push(data);
                    tableInput.value = '';
                    notesInput.value = '';
                    currentTabId = data.id;
                    renderTabs();
                    renderCurrentTab();
                    closeTabPanel();
                })
                .catch(err => {
                    alert(err.message);
                });
        }

        function updateTabStatus(tabId, status) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const payload = { tabId, status };

            fetch('@Url.Action("UpdateTabStatus", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Update tab failed.');
                    }
                    return response.json();
                })
                .then(data => {
                    const tab = tabs.find(t => t.id === data.id);
                    if (tab) {
                        tab.status = data.status;
                    }
                    if (currentTabId === data.id && data.status === 2) {
                        currentTabId = null;
                    }
                    renderTabs();
                    renderCurrentTab();
                })
                .catch(err => {
                    alert(err.message);
                    renderTabs();
                });
        }

        function renderCategories() {
            const list = document.getElementById('categoryList');
            list.innerHTML = '';
            
            const allBtn = document.createElement('button');
            allBtn.className = 'category-btn' + (currentCategoryId === null ? ' active' : '');
            allBtn.innerText = 'All Items';
            allBtn.onclick = () => selectCategory(null, 'All Items');
            list.appendChild(allBtn);

            categories.forEach(c => {
                const btn = document.createElement('button');
                btn.className = 'category-btn' + (currentCategoryId === c.id ? ' active' : '');
                btn.innerText = c.name;
                btn.onclick = () => selectCategory(c.id, c.name);
                list.appendChild(btn);
            });
        }

        function selectCategory(id, name) {
            currentCategoryId = id;
            document.getElementById('currentCategoryTitle').innerText = name;
            renderCategories();
            renderProducts();
        }

        function renderProducts() {
            const list = document.getElementById('productList');
            list.innerHTML = '';
            
            const filtered = currentCategoryId 
                ? products.filter(p => p.productCategoryId === currentCategoryId)
                : products;

            filtered.forEach(p => {
                const card = document.createElement('div');
                card.className = 'product-card';
                card.onclick = () => addToOrder(p);
                card.innerHTML = `
                    <div class="product-name">${p.name}</div>
                    <div class="product-price">$${p.unitPrice.toFixed(2)}</div>
                `;
                list.appendChild(card);
            });
        }

        function addToOrder(product) {
            const existing = order.find(item => item.product.id === product.id);
            if (existing) {
                existing.qty++;
            } else {
                order.push({ product, qty: 1 });
            }
            renderReceipt();
        }

        function renderReceipt() {
            const list = document.getElementById('receiptList');
            list.innerHTML = '';
            
            let total = 0;

            order.forEach(item => {
                const itemTotal = item.product.unitPrice * item.qty;
                total += itemTotal;
                
                const div = document.createElement('div');
                div.className = 'receipt-item';
                div.innerHTML = `
                    <div style="display: flex; align-items: center;">
                        <span class="item-qty">${item.qty}</span>
                        <span class="item-name">${item.product.name}</span>
                    </div>
                    <span class="item-total">$${itemTotal.toFixed(2)}</span>
                `;
                list.appendChild(div);
            });

            document.getElementById('receiptTotal').innerText = '$' + total.toFixed(2);
        }

        function checkout() {
            if (order.length === 0) {
                alert("Cart is empty!");
                return;
            }

            if (!currentTabId) {
                alert("Select a customer tab first.");
                return;
            }

            const payload = {
                customerTabId: currentTabId,
                items: order.map(item => ({
                    productId: item.product.id,
                    quantity: item.qty
                }))
            };

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('@Url.Action("Checkout", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Checkout failed.');
                    }
                    return response.json();
                })
                .then(data => {
                    alert(`Order ${data.orderNumber} charged. Total: $${Number(data.total).toFixed(2)}`);
                    order = [];
                    renderReceipt();
                })
                .catch(err => {
                    alert(err.message);
                });
        }

        // Initialize
        renderCategories();
        renderProducts();
        renderTabs();
        renderCurrentTab();
        renderReceipt();
    </script>
}