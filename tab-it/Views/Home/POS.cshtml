@{
    ViewData["Title"] = "POS Terminal";
    ViewData["HideShell"] = true;
    Layout = "_Layout";
}
@using System.Text.Json

<style>
    :root {
        --pos-bg: #edf1eb;
        --pos-soft: #f7f7f3;
        --pos-card: #FFFFFF;
        --pos-border: rgba(0, 0, 0, 0.08);
        --pos-accent: #ffb424;
        --pos-accent-strong: #e19800;
        --pos-accent-soft: #fef6e3;
        --pos-secondary: #195349;
        --pos-secondary-soft: #eaf2ef;
        --pos-text: #1a1a1a;
        --pos-muted: #595959;
        --pos-radius: 12px;
        --pos-radius-sm: 9px;
        --pos-pill: 9999px;
        --pos-shadow: 0 14px 44px rgba(0, 0, 0, 0.08);
        --pos-shadow-soft: 0 8px 28px rgba(0, 0, 0, 0.045);
    }

    body.pos-mode {
        background-color: var(--pos-bg);
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--pos-text);
        overflow: hidden; /* Prevent body scrolling if possible */
    }

    .pos-container {
        display: grid;
        grid-template-columns: 220px 1fr 340px;
        height: 100vh;
        width: 100%;
        gap: 1.1rem;
        padding: 1.1rem;
        box-sizing: border-box;
        background-color: var(--pos-bg);
    }

    /* Common Card Styles */
    .pos-panel {
        background: var(--pos-card);
        border: 0;
        border-radius: var(--pos-radius);
        padding: 1rem;
        box-shadow: var(--pos-shadow-soft);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-sizing: border-box;
    }

    .category-btn:focus-visible,
    .product-card:focus-visible,
    .btn-checkout:focus-visible,
    .pos-tab-current:focus-visible,
    .pos-tab-btn:focus-visible,
    .pos-tab-panel-close:focus-visible,
    .pos-open-tab-btn:focus-visible,
    .pos-tab-close:focus-visible,
    .pos-payment-method:focus-visible,
    .pos-new-tab button:focus-visible,
    .pos-new-tab input:focus-visible {
        outline: 3px solid rgba(255, 180, 36, 0.35);
        outline-offset: 2px;
    }
    
    .pos-panel-title {
        color: var(--pos-secondary);
        font-weight: 900;
        font-size: 1.05rem;
        margin-bottom: 1rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px solid var(--pos-border);
    }

    /* Left: Categories */
    .pos-categories {
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .category-btn {
        background: var(--pos-soft);
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.78rem 0.9rem;
        color: var(--pos-text);
        font-weight: 800;
        cursor: pointer;
        text-align: left;
        box-shadow: inset 0 0 0 1px var(--pos-border);
        transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
    }
    .category-btn:hover {
        background: var(--pos-accent-soft);
        color: var(--pos-accent-strong);
    }
    .category-btn.active {
        background: var(--pos-secondary);
        color: #ffffff;
        box-shadow: none;
    }

    /* Middle: Products */
    .pos-products {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 0.85rem;
        overflow-y: auto;
        align-content: start;
        padding-bottom: 1rem;
    }

    .product-card {
        background: var(--pos-card);
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.65rem;
        text-align: left;
        cursor: pointer;
        transition: transform 0.14s ease, box-shadow 0.14s ease, background 0.14s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 184px;
        user-select: none;
        box-shadow: inset 0 0 0 1px var(--pos-border);
        overflow: hidden;
    }
    .product-card:hover {
        transform: translateY(-2px);
        background: #fbfbf8;
        box-shadow: inset 0 0 0 1px rgba(25, 83, 73, 0.18), var(--pos-shadow-soft);
    }
    .product-card:active {
        transform: translateY(1px);
        box-shadow: inset 0 0 0 1px var(--pos-border);
    }
    .product-card.disabled {
        opacity: 0.45;
        cursor: not-allowed;
        filter: grayscale(0.3);
    }
    .product-card.disabled:hover {
        transform: none;
        box-shadow: inset 0 0 0 1px var(--pos-border);
    }
    .product-name {
        font-weight: 850;
        font-size: 1rem;
        line-height: 1.25;
    }
    .product-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        border-radius: 8px;
        object-fit: cover;
        background: var(--pos-secondary-soft);
        margin-bottom: 0.65rem;
        display: block;
    }
    .product-image-placeholder {
        width: 100%;
        aspect-ratio: 4 / 3;
        border-radius: 8px;
        background: var(--pos-secondary-soft);
        color: var(--pos-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.65rem;
        font-weight: 900;
        font-size: 1.6rem;
    }
    .product-price {
        font-weight: 800;
        color: var(--pos-secondary);
        margin-top: 0.75rem;
        font-size: 1rem;
    }

    /* Right: Receipt */
    .pos-receipt {
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .receipt-items {
        flex: 1;
        overflow-y: auto;
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.6rem;
        background: var(--pos-soft);
        margin-bottom: 1rem;
    }
    .receipt-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0.5rem;
        border-bottom: 1px solid var(--pos-border);
    }
    .receipt-item:last-child {
        border-bottom: none;
    }
    .item-qty {
        font-weight: 800;
        margin-right: 0.5rem;
        background: var(--pos-secondary);
        color: #ffffff;
        padding: 2px 8px;
        border-radius: 8px;
        font-size: 0.9em;
    }
    .item-name {
        flex: 1;
        font-weight: 800;
    }
    .item-total {
        font-weight: 800;
        margin-left: 0.5rem;
    }

    .receipt-total {
        color: var(--pos-secondary);
        font-size: 1.35rem;
        font-weight: 900;
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--pos-border);
    }

    .btn-checkout {
        background: var(--pos-accent);
        color: var(--pos-text);
        border: 0;
        border-radius: var(--pos-radius);
        padding: 1.05rem;
        font-weight: 900;
        font-size: 1.05rem;
        cursor: pointer;
        text-transform: uppercase;
        box-shadow: none;
        transition: transform 0.12s ease, background 0.12s ease;
        margin-top: auto;
    }
    .btn-checkout:active {
        transform: translateY(1px);
        box-shadow: none;
    }
    .btn-checkout:hover {
        background: var(--pos-accent-strong);
    }

    .btn-checkout.is-sending {
        pointer-events: none;
        animation: posSendFly 0.9s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .btn-checkout.is-busy {
        pointer-events: none;
        filter: saturate(0.8);
    }

    .pos-send-feedback {
        min-height: 1.35rem;
        margin-top: 0.75rem;
        color: var(--pos-muted);
        font-size: 0.92rem;
        font-weight: 800;
        text-align: center;
    }

    .pos-send-feedback.error {
        color: #9b2c2c;
    }

    .pos-send-feedback.success {
        color: var(--pos-secondary);
    }

    @@keyframes posSendFly {
        0% {
            transform: translateX(0) translateY(0) rotate(0deg) scale(1);
            opacity: 1;
        }
        18% {
            transform: translateX(-10px) translateY(-2px) rotate(-1deg) scale(1.02);
            opacity: 1;
        }
        70% {
            transform: translateX(88vw) translateY(-12px) rotate(5deg) scale(0.98);
            opacity: 1;
        }
        100% {
            transform: translateX(120vw) translateY(-18px) rotate(7deg) scale(0.92);
            opacity: 0;
        }
    }

    /* Header Nav in POS */
    .pos-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--pos-border);
    }
    .pos-nav-logo {
        font-weight: 900;
        font-size: 1.25rem;
        color: var(--pos-text);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .pos-nav-exit {
        font-weight: 800;
        color: var(--pos-text);
        text-decoration: none;
        border: 0;
        padding: 0.25rem 0.75rem;
        border-radius: var(--pos-radius-sm);
        transition: background 0.2s;
        font-size: 0.9rem;
        background: var(--pos-soft);
        box-shadow: inset 0 0 0 1px var(--pos-border);
    }
    .pos-nav-exit:hover {
        background: #f0f0f0;
    }

    .pos-tab-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .pos-tab-current {
        width: 100%;
        border: 0;
        border-radius: var(--pos-radius-sm);
        background: var(--pos-secondary-soft);
        color: var(--pos-secondary);
        padding: 0.85rem;
        margin-bottom: 0.85rem;
        text-align: left;
        cursor: pointer;
        box-shadow: inset 0 0 0 1px rgba(36, 92, 80, 0.12);
    }

    .pos-tab-current-label {
        display: block;
        color: var(--pos-muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .pos-tab-current-value {
        display: block;
        margin-top: 0.15rem;
        font-size: 1rem;
        font-weight: 900;
    }

    .pos-tab-btn {
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.4rem 0.85rem;
        font-weight: 800;
        background: var(--pos-secondary);
        color: #ffffff;
        cursor: pointer;
    }

    .pos-tab-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 20;
    }

    .pos-tab-overlay.active {
        display: flex;
    }

    .pos-tab-panel {
        width: min(680px, 92vw);
        background: var(--pos-card);
        border: 0;
        border-radius: var(--pos-radius);
        box-shadow: var(--pos-shadow);
        padding: 1.1rem;
        box-sizing: border-box;
    }

    .pos-tab-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--pos-border);
    }

    .pos-tab-panel-title {
        font-size: 1.25rem;
        font-weight: 900;
    }

    .pos-tab-panel-close {
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.25rem 0.75rem;
        font-weight: 800;
        background: var(--pos-soft);
        cursor: pointer;
    }

    .pos-open-tabs {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.7rem;
        margin-bottom: 1rem;
        max-height: 46vh;
        overflow-y: auto;
    }

    .pos-tab-entry {
        display: block;
    }

    .pos-tab-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pos-open-tab-btn {
        width: 100%;
        min-height: 88px;
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.75rem;
        font-weight: 800;
        background: var(--pos-soft);
        color: var(--pos-text);
        cursor: pointer;
        text-align: left;
        box-shadow: inset 0 0 0 1px var(--pos-border);
    }

    .pos-open-tab-btn.active {
        background: var(--pos-secondary);
        color: #ffffff;
        box-shadow: none;
    }

    .pos-tab-card-title {
        display: block;
        font-size: 1.05rem;
    }

    .pos-tab-card-sub {
        display: block;
        margin-top: 0.25rem;
        color: currentColor;
        opacity: 0.72;
        font-size: 0.85rem;
    }

    .pos-tab-close {
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.45rem 0.75rem;
        font-weight: 900;
        background: var(--pos-accent);
        color: var(--pos-text);
        width: 100%;
        box-sizing: border-box;
        margin-top: 0.45rem;
        cursor: pointer;
    }

    .pos-tab-close:disabled {
        background: #e2e0d8;
        color: #8a877f;
        cursor: not-allowed;
        box-shadow: none;
    }

    .pos-payment-methods {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .pos-payment-method {
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 1rem;
        min-height: 88px;
        background: var(--pos-soft);
        font-weight: 900;
        cursor: pointer;
        box-shadow: inset 0 0 0 1px var(--pos-border);
    }

    .pos-payment-method.active {
        background: var(--pos-secondary);
        color: #ffffff;
        box-shadow: none;
    }

    .pos-payment-summary {
        background: var(--pos-secondary-soft);
        color: var(--pos-secondary);
        border-radius: var(--pos-radius-sm);
        padding: 0.85rem;
        margin-bottom: 1rem;
        font-weight: 800;
    }

    .pos-new-tab {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .pos-new-tab input {
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.5rem 0.6rem;
        font-weight: 700;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        background: var(--pos-soft);
    }

    .pos-new-tab button {
        grid-column: span 2;
        border: 0;
        border-radius: var(--pos-radius-sm);
        padding: 0.6rem 1rem;
        font-weight: 900;
        background: var(--pos-accent);
        color: var(--pos-text);
        cursor: pointer;
        width: 100%;
        box-sizing: border-box;
    }

    @@media (max-width: 1050px) {
        .pos-container {
            grid-template-columns: 180px 1fr;
            overflow-y: auto;
            height: auto;
            min-height: 100vh;
        }

        .pos-receipt {
            grid-column: 1 / -1;
            min-height: 420px;
        }
    }

    @@media (max-width: 720px) {
        body.pos-mode {
            overflow: auto;
        }

        .pos-container {
            grid-template-columns: 1fr;
        }

        .pos-payment-methods {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="pos-container">
    <!-- Categories -->
    <div class="pos-panel">
        <div class="pos-nav">
            <a href="/" class="pos-nav-logo">
                <img src="~/images/tab-it.svg" width="20" height="20" alt="" />
                <span>tab_it</span>
            </a>
            <a asp-controller="Home" asp-action="Dashboard" class="pos-nav-exit">Exit</a>
        </div>
        <h2 class="pos-panel-title">Categories</h2>
        <div class="pos-categories" id="categoryList">
            <!-- Populated by JS -->
        </div>
    </div>

    <!-- Products -->
    <div class="pos-panel">
        <h2 class="pos-panel-title" id="currentCategoryTitle">All Items</h2>
        <div class="pos-products" id="productList">
            <!-- Populated by JS -->
        </div>
    </div>

    <!-- Receipt -->
    <div class="pos-panel pos-receipt">
        <div class="pos-tab-row">
            <h2 class="pos-panel-title" style="margin-bottom: 0;">Current Order</h2>
            <button class="pos-tab-btn" type="button" onclick="openTabPanel()">Change</button>
        </div>
        <button class="pos-tab-current" id="currentTabButton" type="button" onclick="openTabPanel()">
            <span class="pos-tab-current-label">Active table</span>
            <span class="pos-tab-current-value" id="currentTabLabel">No tab selected</span>
        </button>
        @Html.AntiForgeryToken()
        <div class="receipt-items" id="receiptList">
            <!-- Populated by JS -->
        </div>
        
        <div class="receipt-total">
            <span>Total</span>
            <span id="receiptTotal">$0.00</span>
        </div>

        <button class="btn-checkout" id="sendOrderButton" onclick="checkout()"> Send </button>
        <div class="pos-send-feedback" id="sendOrderFeedback" aria-live="polite"></div>
    </div>
</div>

<div class="pos-tab-overlay" id="tabOverlay">
    <div class="pos-tab-panel">
        <div class="pos-tab-panel-header">
            <div class="pos-tab-panel-title">Manage Tabs</div>
            <button class="pos-tab-panel-close" type="button" onclick="closeTabPanel()">Close</button>
        </div>
        <div class="pos-open-tabs" id="openTabsList"></div>
        <div class="pos-new-tab">
            <input id="newTabTable" type="number" min="1" placeholder="Table #" />
            <input id="newTabNotes" type="text" maxlength="500" placeholder="Notes (optional)" />
            <button type="button" onclick="createTab()">Open New Tab</button>
        </div>
    </div>
</div>

<div class="pos-tab-overlay" id="paymentOverlay">
    <div class="pos-tab-panel">
        <div class="pos-tab-panel-header">
            <div class="pos-tab-panel-title">Close Table</div>
            <button class="pos-tab-panel-close" type="button" onclick="closePaymentPanel()">Cancel</button>
        </div>
        <div class="pos-payment-summary" id="paymentSummary">Select a payment method.</div>
        <div class="pos-payment-methods">
            <button class="pos-payment-method" type="button" data-payment="Cash" onclick="selectPaymentMethod('Cash')">Cash</button>
            <button class="pos-payment-method" type="button" data-payment="Credit Card" onclick="selectPaymentMethod('Credit Card')">Credit Card</button>
            <button class="pos-payment-method" type="button" data-payment="Debit Card" onclick="selectPaymentMethod('Debit Card')">Debit Card</button>
        </div>
        <button class="btn-checkout" type="button" onclick="closeTabWithPayment()">Generate Receipt</button>
    </div>
</div>

@section Scripts {
    <script>
        document.body.classList.add('pos-mode');

        // Data from Repositories
        const categories = @Html.Raw(JsonSerializer.Serialize(ViewData["Categories"] ?? Array.Empty<object>(), new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
        const products = @Html.Raw(JsonSerializer.Serialize(ViewData["Products"] ?? Array.Empty<object>(), new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
        const tabs = @Html.Raw(JsonSerializer.Serialize(ViewData["Tabs"] ?? Array.Empty<object>(), new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));

        let currentCategoryId = null;
        let order = [];
        let currentTabId = null;
        let closingTabId = null;
        let selectedPaymentMethod = null;

        function renderTabs() {
            const openTabsList = document.getElementById('openTabsList');
            openTabsList.innerHTML = '';

            const openTabs = tabs.filter(t => t.status !== 2);
            openTabs.forEach(t => {
                const entry = document.createElement('div');
                entry.className = 'pos-tab-entry';

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'pos-open-tab-btn' + (currentTabId === t.id ? ' active' : '');
                btn.innerHTML = `
                    <span class="pos-tab-card-title">Table ${t.tableNumber}</span>
                    <span class="pos-tab-card-sub">Open tab</span>
                `;
                btn.onclick = () => {
                    currentTabId = t.id;
                    renderTabs();
                    renderCurrentTab();
                    closeTabPanel();
                };

                const actions = document.createElement('div');
                actions.className = 'pos-tab-actions';

                const closeBtn = document.createElement('button');
                closeBtn.type = 'button';
                closeBtn.className = 'pos-tab-close';
                closeBtn.disabled = !t.canClose;
                closeBtn.textContent = t.canClose
                    ? `Close - $${Number(t.total || 0).toFixed(2)}`
                    : `${t.pendingOrders || 0} pending`;
                closeBtn.onclick = event => {
                    event.stopPropagation();
                    if (t.canClose) {
                        openPaymentPanel(t.id);
                    }
                };

                actions.appendChild(closeBtn);
                entry.appendChild(btn);
                entry.appendChild(actions);
                openTabsList.appendChild(entry);
            });

            if (openTabs.length === 0) {
                const empty = document.createElement('div');
                empty.className = 'text-muted';
                empty.textContent = 'No open tabs. Open a new table below.';
                openTabsList.appendChild(empty);
            }
        }

        function renderCurrentTab() {
            const label = document.getElementById('currentTabLabel');
            const tab = tabs.find(t => t.id === currentTabId);
            label.textContent = tab
                ? `Table ${tab.tableNumber}`
                : 'No tab selected';
        }

        function selectDefaultTab() {
            if (currentTabId) {
                return;
            }

            const openTabs = tabs.filter(t => t.status !== 2);
            if (openTabs.length === 1) {
                currentTabId = openTabs[0].id;
            }
        }

        function openTabPanel() {
            document.getElementById('tabOverlay').classList.add('active');
            renderTabs();
        }

        function closeTabPanel() {
            document.getElementById('tabOverlay').classList.remove('active');
        }

        function createTab() {
            const tableInput = document.getElementById('newTabTable');
            const notesInput = document.getElementById('newTabNotes');
            const tableNumber = parseInt(tableInput.value, 10);
            if (!tableNumber) {
                alert('Enter a table number.');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const payload = {
                tableNumber,
                notes: notesInput.value
            };

            fetch('@Url.Action("CreateTab", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Create tab failed.');
                    }
                    return response.json();
                })
                .then(data => {
                    tabs.push(data);
                    tableInput.value = '';
                    notesInput.value = '';
                    currentTabId = data.id;
                    renderTabs();
                    renderCurrentTab();
                    closeTabPanel();
                })
                .catch(err => {
                    alert(err.message);
                });
        }

        function openPaymentPanel(tabId) {
            const tab = tabs.find(t => t.id === tabId);
            if (!tab || !tab.canClose) {
                return;
            }

            closingTabId = tabId;
            selectedPaymentMethod = null;
            document.querySelectorAll('.pos-payment-method').forEach(button => button.classList.remove('active'));
            document.getElementById('paymentSummary').textContent = `Table ${tab.tableNumber} total: $${Number(tab.total || 0).toFixed(2)}`;
            document.getElementById('paymentOverlay').classList.add('active');
        }

        function closePaymentPanel() {
            document.getElementById('paymentOverlay').classList.remove('active');
            closingTabId = null;
            selectedPaymentMethod = null;
        }

        function selectPaymentMethod(method) {
            selectedPaymentMethod = method;
            document.querySelectorAll('.pos-payment-method').forEach(button => {
                button.classList.toggle('active', button.dataset.payment === method);
            });
        }

        function closeTabWithPayment() {
            if (!closingTabId) {
                return;
            }

            if (!selectedPaymentMethod) {
                alert('Select a payment method.');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const payload = {
                tabId: closingTabId,
                paymentMethod: selectedPaymentMethod
            };

            fetch('@Url.Action("CloseTab", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Close tab failed.');
                    }
                    return response.blob();
                })
                .then(blob => {
                    const tab = tabs.find(t => t.id === closingTabId);
                    if (tab) {
                        tab.status = 2;
                        tab.canClose = false;
                    }
                    if (currentTabId === closingTabId) {
                        currentTabId = null;
                    }

                    const receiptUrl = URL.createObjectURL(blob);
                    window.open(receiptUrl, '_blank');
                    closePaymentPanel();
                    renderTabs();
                    renderCurrentTab();
                })
                .catch(err => {
                    alert(err.message);
                });
        }

        function renderCategories() {
            const list = document.getElementById('categoryList');
            list.innerHTML = '';
            
            const allBtn = document.createElement('button');
            allBtn.className = 'category-btn' + (currentCategoryId === null ? ' active' : '');
            allBtn.innerText = 'All Items';
            allBtn.onclick = () => selectCategory(null, 'All Items');
            list.appendChild(allBtn);

            categories.forEach(c => {
                const btn = document.createElement('button');
                btn.className = 'category-btn' + (currentCategoryId === c.id ? ' active' : '');
                btn.innerText = c.name;
                btn.onclick = () => selectCategory(c.id, c.name);
                list.appendChild(btn);
            });
        }

        function selectCategory(id, name) {
            currentCategoryId = id;
            document.getElementById('currentCategoryTitle').innerText = name;
            renderCategories();
            renderProducts();
        }

        function renderProducts() {
            const list = document.getElementById('productList');
            list.innerHTML = '';
            
            const filtered = currentCategoryId 
                ? products.filter(p => p.productCategoryId === currentCategoryId)
                : products;

            filtered.forEach(p => {
                const card = document.createElement('div');
                card.className = 'product-card';
                if (!p.canSell) {
                    card.classList.add('disabled');
                } else {
                    card.onclick = () => addToOrder(p);
                }
                const imageHtml = p.imagePath
                    ? `<img class="product-image" src="${p.imagePath}" alt="${p.name}">`
                    : `<div class="product-image-placeholder" aria-hidden="true">${p.name.substring(0, 1).toUpperCase()}</div>`;
                card.innerHTML = `
                    <div>
                        ${imageHtml}
                        <div class="product-name">${p.name}</div>
                    </div>
                    <div class="product-price">${p.canSell ? `$${p.unitPrice.toFixed(2)}` : 'Out of stock'}</div>
                `;
                list.appendChild(card);
            });
        }

        function addToOrder(product) {
            const existing = order.find(item => item.product.id === product.id);
            if (existing) {
                existing.qty++;
            } else {
                order.push({ product, qty: 1 });
            }
            renderReceipt();
        }

        function renderReceipt() {
            const list = document.getElementById('receiptList');
            list.innerHTML = '';
            
            let total = 0;

            order.forEach(item => {
                const itemTotal = item.product.unitPrice * item.qty;
                total += itemTotal;
                
                const div = document.createElement('div');
                div.className = 'receipt-item';
                div.innerHTML = `
                    <div style="display: flex; align-items: center;">
                        <span class="item-qty">${item.qty}</span>
                        <span class="item-name">${item.product.name}</span>
                    </div>
                    <span class="item-total">$${itemTotal.toFixed(2)}</span>
                `;
                list.appendChild(div);
            });

            document.getElementById('receiptTotal').innerText = '$' + total.toFixed(2);
        }

        function setSendFeedback(message, type) {
            const feedback = document.getElementById('sendOrderFeedback');
            feedback.textContent = message || '';
            feedback.classList.toggle('error', type === 'error');
            feedback.classList.toggle('success', type === 'success');
        }

        function animateSendButton(total) {
            const button = document.getElementById('sendOrderButton');
            button.classList.remove('is-busy');
            button.classList.add('is-sending');
            button.textContent = 'Sent';
            setSendFeedback(`Order sent - $${Number(total || 0).toFixed(2)}`, 'success');

            window.setTimeout(() => {
                button.classList.remove('is-sending');
                button.textContent = 'Send';
            }, 950);
        }

        function checkout() {
            if (order.length === 0) {
                setSendFeedback('Cart is empty.', 'error');
                return;
            }

            if (!currentTabId) {
                openTabPanel();
                setSendFeedback('Select a customer tab first.', 'error');
                return;
            }

            const sendButton = document.getElementById('sendOrderButton');
            if (sendButton.classList.contains('is-busy') || sendButton.classList.contains('is-sending')) {
                return;
            }

            sendButton.classList.add('is-busy');
            sendButton.textContent = 'Sending';
            setSendFeedback('', '');

            const payload = {
                customerTabId: currentTabId,
                items: order.map(item => ({
                    productId: item.product.id,
                    quantity: item.qty
                }))
            };

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('@Url.Action("Checkout", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
                .then(async response => {
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.message || 'Checkout failed.');
                    }
                    return response.json();
                })
                .then(data => {
                    const tab = tabs.find(t => t.id === currentTabId);
                    if (tab) {
                        tab.total = Number(tab.total || 0) + Number(data.total || 0);
                        tab.pendingOrders = Number(tab.pendingOrders || 0) + 1;
                        tab.canClose = false;
                    }
                    order = [];
                    renderReceipt();
                    animateSendButton(data.total);
                })
                .catch(err => {
                    sendButton.classList.remove('is-busy');
                    sendButton.textContent = 'Send';
                    setSendFeedback(err.message, 'error');
                });
        }

        // Initialize
        renderCategories();
        renderProducts();
        selectDefaultTab();
        renderTabs();
        renderCurrentTab();
        renderReceipt();
    </script>
}
