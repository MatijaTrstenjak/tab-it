<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - tab_it</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/tab_it.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var hideShell = (ViewData["HideShell"] as bool?) == true;
    var bodyClass = ViewData["BodyClass"] as string ?? string.Empty;
}
<body class="@bodyClass">
    <a class="app-skip-link" href="#app-main-content">Skip to main content</a>
    @if (!hideShell)
    {
    <div class="app-shell">
        <aside class="app-sidebar" aria-label="Primary">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Dashboard" style="display: flex; align-items: center; gap: 8px;">
                <img src="~/images/tab-it.svg" width="24" height="24" alt="tab_it logo" />
                <span>tab_it</span>
            </a>
            <nav class="app-menu" aria-label="Main menu" id="app-main-menu">
                <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                <a asp-controller="Home" asp-action="POS">POS App</a>
                <a asp-controller="Orders" asp-action="Index">Orders</a>
                <a asp-controller="CustomerTabs" asp-action="Index">Tables</a>
                <a asp-controller="Products" asp-action="Index">Menu</a>
                <a asp-controller="InventoryItems" asp-action="Index">Inventory</a>
                <a asp-controller="ProductRecipeItems" asp-action="Index">Recipes</a>
                <a href="#">Accounting</a>
                
                <h6 class="app-menu-heading" style="margin-top: 2rem; margin-bottom: 0.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--app-muted); padding: 0 0.75rem;">Settings</h6>
                <a asp-controller="Roles" asp-action="Index">Roles</a>
                <a asp-controller="Users" asp-action="Index">Users</a>
                <a asp-controller="ProductCategories" asp-action="Index">Product Categories</a>
                <a asp-controller="OrderItems" asp-action="Index">Order Items</a>
            </nav>
            <div class="app-sidebar-footer" style="margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--app-border);">
                <div style="display: flex; align-items: center; gap: 8px; padding: 0 0.5rem;">
                    <div style="width: 32px; height: 32px; background: var(--app-accent-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--app-accent-strong); font-weight: bold;">
                        U
                    </div>
                    <div style="flex: 1; overflow: hidden;">
                        <div style="font-size: 0.9rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--app-text);">User Name</div>
                        <div style="font-size: 0.75rem; color: var(--app-muted);">Admin</div>
                    </div>
                    <a href="#" style="color: var(--app-muted); text-decoration: none; padding: 4px; display: flex;" title="Logout">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                          <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                          <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </aside>

        <div class="app-main-shell">
            <header class="app-top-row" role="banner">
                <button class="app-menu-toggle" type="button" aria-controls="app-main-menu" aria-expanded="false">Menu</button>
            </header>

            <section class="app-breadcrumb-row" aria-label="Breadcrumbs">
                @if (IsSectionDefined("Breadcrumbs"))
                {
                    @RenderSection("Breadcrumbs", required: false)
                }
                else
                {
                    <nav aria-label="breadcrumb" class="app-breadcrumbs">
                        <ol>
                            <li><a asp-controller="Home" asp-action="Dashboard">Home</a></li>
                        </ol>
                    </nav>
                }
            </section>

            <main role="main" class="app-main-content" id="app-main-content">
                @RenderBody()
            </main>

            <footer class="app-footer text-muted">
                <span>&copy; 2026 - tab_it</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </footer>
        </div>
    </div>
    }
    @if (hideShell)
    {
        <div class="container-fluid p-0">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/hr.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Global Bootstrap Modal for Dynamic Form Loading -->
    <div class="modal fade" id="globalFormModal" tabindex="-1" aria-labelledby="globalFormModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="globalFormModalLabel">Add New</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id="globalFormModalBody">
            <div class="text-center">Loading...</div>
          </div>
        </div>
      </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
