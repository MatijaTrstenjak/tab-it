<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - tab_it</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/tab_it.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var hideShell = (ViewData["HideShell"] as bool?) == true;
    var bodyClass = ViewData["BodyClass"] as string ?? string.Empty;
}
<body class="@bodyClass">
    <a class="app-skip-link" href="#app-main-content">Skip to main content</a>
    @if (!hideShell)
    {
    <div class="app-shell">
        <aside class="app-sidebar" aria-label="Primary">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Dashboard" style="display: flex; align-items: center; gap: 8px;">
                <img src="~/images/tab-it.svg" width="24" height="24" alt="tab_it logo" />
                <span>tab_it</span>
            </a>
            <nav class="app-menu" aria-label="Main menu" id="app-main-menu">
                <a asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                <a asp-controller="Roles" asp-action="Index">Roles</a>
                <a asp-controller="Users" asp-action="Index">Users</a>
                <a asp-controller="ProductCategories" asp-action="Index">Product Categories</a>
                <a asp-controller="Products" asp-action="Index">Products</a>
                <a asp-controller="CustomerTabs" asp-action="Index">Customer Tabs</a>
                <a asp-controller="Orders" asp-action="Index">Orders</a>
                <a asp-controller="OrderItems" asp-action="Index">Order Items</a>
            </nav>
        </aside>

        <div class="app-main-shell">
            <header class="app-top-row" role="banner">
                <button class="app-menu-toggle" type="button" aria-controls="app-main-menu" aria-expanded="false">Menu</button>
            </header>

            <section class="app-breadcrumb-row" aria-label="Breadcrumbs">
                @if (IsSectionDefined("Breadcrumbs"))
                {
                    @RenderSection("Breadcrumbs", required: false)
                }
                else
                {
                    <nav aria-label="breadcrumb" class="app-breadcrumbs">
                        <ol>
                            <li><a asp-controller="Home" asp-action="Dashboard">Home</a></li>
                        </ol>
                    </nav>
                }
            </section>

            <main role="main" class="app-main-content" id="app-main-content">
                @RenderBody()
            </main>

            <footer class="app-footer text-muted">
                <span>&copy; 2026 - tab_it</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </footer>
        </div>
    </div>
    }
    @if (hideShell)
    {
        <div class="container-fluid p-0">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
