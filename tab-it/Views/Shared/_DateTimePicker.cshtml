@model DateTime?

@{
    var field = ViewData["Field"] as string ?? string.Empty;
    var label = ViewData["Label"] as string ?? field;
    var formatted = Model.HasValue ? Model.Value.ToString("yyyy-MM-dd HH:mm") : string.Empty;
}

<div class="form-group mb-3">
    @Html.Label(field, label, new { @class = "control-label" })
    @Html.TextBox(field, formatted, new { @class = "form-control js-datetime", data_role = "datetime", type = "text" })
    @Html.ValidationMessage(field, string.Empty, new { @class = "text-danger" })
</div>
